ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.vercel.app

# RAG (optionnel — sans ces 3 variables, la génération fonctionne toujours,
# mais sans contexte documentaire : upload/retrieval renverront une erreur)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
PINECONE_API_KEY=YOUR_PINECONE_KEY_HERE
PINECONE_INDEX_URL=https://your-index.svc.your-region.pinecone.io

# Mode démo publique (optionnel — désactive upload/suppression de documents)
DEMO_MODE=false
